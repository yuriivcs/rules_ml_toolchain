"""ROCm hermetic toolchain wrapper.

This wrapper handles three distinct compilation modes:

1. GPU Compilation (-x rocm flag present):
   - Uses hipcc from ROCm toolkit
   - Filters hermetic LLVM headers (conflict with ROCm's)
   - Uses hermetic sysroot headers for device-compatible standard library
   - Generates dependency files
   - Compiles .cu.cc files for AMD GPUs

2. Host CPU Compilation (default):
   - Uses hermetic clang directly
   - Splits combined flags from Bazel features (e.g., '-isystem path')
   - Uses hermetic headers or system headers depending on sysroot mode
   - Standard C++ compilation for CPU code

3. Linking (-pass-exit-codes flag present):
   - Uses hermetic clang linker
   - Strips ROCm-specific flags (--offload-arch, etc.)
   - Links GPU and CPU objects together

SYNOPSIS:
  hipcc_wrapper [options passed in by cc_library() or cc_binary() rule]

ENVIRONMENT VARIABLES (set by toolchain features):
  GCC_PATH: Path to the host compiler (clang)
  HIPCC_PATH: Path to the hipcc compiler
  ROCM_PATH: Path to the ROCm installation
  ROCM_CLANG_VERSION: ROCm clang version for header paths
  HOST_SYSROOT: Sysroot path for host (CPU) compilation. If set, uses this system
                sysroot for host compilation. If not set, uses hermetic sysroot.
                GPU compilation always uses hermetic sysroot regardless of this setting.
  CROSSTOOL_VERBOSE: Set to "1" to enable verbose logging
"""

from argparse import ArgumentParser
import os
import subprocess
import re
import sys

# Get paths from environment variables set by toolchain features
CPU_COMPILER = os.environ.get("GCC_PATH", "clang")
HIPCC_PATH = os.environ.get("HIPCC_PATH", "/opt/rocm/bin/hipcc")
ROCM_PATH = os.environ.get("ROCM_PATH", "/opt/rocm")
ROCM_CLANG_VERSION = os.environ.get("ROCM_CLANG_VERSION", "20")
HOST_SYSROOT = os.environ.get(
    "HOST_SYSROOT", ""
)  # System sysroot for host compilation (if set)
VERBOSE = os.environ.get("CROSSTOOL_VERBOSE", "0") == "1"


def Log(s):
    """Print a log message with wrapper prefix.

    Args:
        s: Message string to log.
    """
    print("hipcc_wrapper: {0}".format(s))


def GetOptionValue(argv, option):
    """Extract all values for a given option from the argument list.

    This function finds all occurrences of an option and collects their values.
    For example, with argv=['-I', 'path1', '-I', 'path2'], GetOptionValue(argv, 'I')
    returns ['path1', 'path2'].

    Args:
        argv: A list of strings containing command-line arguments.
        option: The option whose value to extract, without the leading '-'.

    Returns:
        A list of values for the option. Returns empty list if option not found.
    """
    parser = ArgumentParser()
    parser.add_argument("-" + option, nargs="*", action="append")
    args, _ = parser.parse_known_args(argv)
    if not args or not vars(args)[option]:
        return []
    else:
        return sum(vars(args)[option], [])


def GetHostCompilerOptions(argv, filter_hermetic_llvm=False, filter_sysroot=False):
    """Collect include paths and sysroot options from argv.

    This function extracts -isystem, -iquote, --sysroot, and -g flags from
    the argument list, with optional filtering for GPU compilation.

    Args:
        argv: A list of strings containing command-line arguments.
        filter_hermetic_llvm: If True, filter out hermetic LLVM headers.
            Used for GPU compilation where ROCm provides its own LLVM headers.
        filter_sysroot: If True, filter out --sysroot flag.
            Used for GPU compilation to avoid system headers.

    Returns:
        A list of options ready to be passed to hipcc or clang.

    Notes:
        - Filters hermetic LLVM headers for GPU (they conflict with ROCm's)
        - Filters sysroot headers for GPU (incompatible with ROCm clang)
        - Used by InvokeHipcc to build GPU compiler options
    """
    parser = ArgumentParser()
    parser.add_argument("-isystem", nargs="*", action="append")
    parser.add_argument("-iquote", nargs="*", action="append")
    parser.add_argument("--sysroot", nargs=1)
    parser.add_argument("-g", nargs="*", action="append")
    parser.add_argument("-no-canonical-prefixes", action="store_true")

    args, _ = parser.parse_known_args(argv)

    opts = []

    if args.isystem:
        for p in sum(args.isystem, []):
            # Skip hermetic LLVM headers for GPU compilation - they conflict with ROCm's
            # ROCm provides its own LLVM headers via --rocm-path
            if filter_hermetic_llvm and "/llvm" in p and "/clang/" in p:
                continue
            # Skip sysroot headers for GPU compilation - they have non-device-compatible operator new
            # ROCm provides device-compatible standard library headers via cuda_wrappers
            if filter_sysroot and "/sysroot_" in p:
                continue
            opts.extend(["-isystem", p])
    if args.iquote:
        for p in sum(args.iquote, []):
            opts.extend(["-iquote", p])
    if args.g:
        opts.append("-g" + "".join(sum(args.g, [])))
    if args.no_canonical_prefixes:
        opts.append("-no-canonical-prefixes")
    if args.sysroot and not filter_sysroot:
        opts.extend(["--sysroot", args.sysroot[0]])

    return opts


def GetHipccOptions(argv):
    """Collect ROCm/hipcc-specific compiler options from argv.

    Extracts GPU-specific flags like --offload-arch (target GPU architecture)
    and -gline-tables-only (debug info for GPU code).

    Args:
        argv: A list of strings containing command-line arguments.

    Returns:
        A list of hipcc-specific options (--offload-arch, -gline-tables-only).
    """
    parser = ArgumentParser()
    parser.add_argument("--offload-arch", nargs="*", action="append")
    parser.add_argument("-gline-tables-only", action="store_true")

    args, _ = parser.parse_known_args(argv)

    hipcc_opts = []
    if args.gline_tables_only:
        hipcc_opts.append("-gline-tables-only")
    if args.offload_arch:
        for a in sum(args.offload_arch, []):
            hipcc_opts.append("--offload-arch=" + a)

    return hipcc_opts


def SplitCombinedFlags(argv):
    """Split combined flags like '-isystem path' into ['-isystem', 'path'].

    Bazel's features.bzl creates combined flags as single arguments
    (e.g., '-isystem /path/to/headers' as one string). The host compiler
    expects them as separate arguments, so we split them here.

    Args:
        argv: A list of strings with potentially combined flags from Bazel.

    Returns:
        A list of strings with combined flags split into separate arguments.

    Notes:
        - Handles common flags: -isystem, -iquote, -I, -MF, -D, -U
        - Removes outermost quotes if present
        - This is only needed for host compilation; hipcc handles combined flags
    """
    split_flags = []
    for arg in argv:
        # Remove outermost quotes if present
        cleaned_arg = arg
        if (arg.startswith("'") and arg.endswith("'")) or (
            arg.startswith('"') and arg.endswith('"')
        ):
            cleaned_arg = arg[1:-1]

        # Split common combined flags
        if cleaned_arg.startswith("-isystem "):
            split_flags.extend(["-isystem", cleaned_arg[9:]])
        elif cleaned_arg.startswith("-iquote "):
            split_flags.extend(["-iquote", cleaned_arg[8:]])
        elif cleaned_arg.startswith("-I "):
            split_flags.extend(["-I", cleaned_arg[3:]])
        elif cleaned_arg.startswith("-MF "):
            split_flags.extend(["-MF", cleaned_arg[4:]])
        elif cleaned_arg.startswith("-D "):
            split_flags.extend(["-D", cleaned_arg[3:]])
        elif cleaned_arg.startswith("-U "):
            split_flags.extend(["-U", cleaned_arg[3:]])
        else:
            split_flags.append(cleaned_arg)

    return split_flags


def InvokeHipcc(argv, log=False):
    """Invoke hipcc for GPU device code compilation.

    This function handles ROCm GPU compilation using the hipcc compiler.
    It processes Bazel's command-line arguments and constructs appropriate
    hipcc compilation commands.

    Args:
        argv: A list of strings containing compilation arguments from Bazel.
        log: True if verbose logging is requested.

    Returns:
        Exit status from the hipcc subprocess.

    Notes:
        - Filters out hermetic LLVM headers (conflict with ROCm's LLVM)
        - Filters out --sysroot=/ for GPU compilation (system headers incompatible)
        - Always uses hermetic sysroot headers for device-compatible standard library
        - Adds ROCm's cuda_wrappers for device-compatible <new>, <cmath>, etc.
        - Generates dependency files if -MF flag is present
        - Uses --rocm-path to point to ROCm installation
    """
    # Split combined flags from Bazel before parsing
    argv = SplitCombinedFlags(argv)

    # Extract GPU-specific options
    hipcc_compiler_options = GetHipccOptions(argv)

    # Extract paths and flags for GPU compilation
    parser = ArgumentParser()
    parser.add_argument("--rocm-path", nargs=1)
    parser.add_argument("-iquote", nargs="*", action="append")
    parser.add_argument("-isystem", nargs="*", action="append")
    parser.add_argument("--sysroot", nargs=1)
    parser.add_argument("-g", nargs="*", action="append")
    parser.add_argument("-no-canonical-prefixes", action="store_true")
    args, _ = parser.parse_known_args(argv)

    rocm_path_arg = args.rocm_path[0] if args.rocm_path else ROCM_PATH

    # Build options for GPU compilation
    # Only include project-specific includes, filter out hermetic LLVM
    gpu_compiler_options = []
    if args.iquote:
        for p in sum(args.iquote, []):
            gpu_compiler_options.extend(["-iquote", p])
    if args.isystem:
        for p in sum(args.isystem, []):
            # Skip hermetic LLVM headers - ROCm provides its own
            if "/llvm" in p and "/clang/" in p:
                continue
            gpu_compiler_options.extend(["-isystem", p])
    if args.sysroot:
        # Skip --sysroot=/ for GPU compilation - system headers are incompatible with ROCm's clang
        # Local sysroot is only for host (CPU) compilation, not GPU
        if args.sysroot[0] != "/":
            gpu_compiler_options.extend(["--sysroot", args.sysroot[0]])
    if args.g:
        gpu_compiler_options.append("-g" + "".join(sum(args.g, [])))
    if args.no_canonical_prefixes:
        gpu_compiler_options.append("-no-canonical-prefixes")

    opt_option = GetOptionValue(argv, "O")
    include_options = GetOptionValue(argv, "I")
    out_file = GetOptionValue(argv, "o")
    depfiles = GetOptionValue(argv, "MF")
    defines = GetOptionValue(argv, "D")
    undefines = GetOptionValue(argv, "U")
    src_files = GetOptionValue(argv, "c")

    if len(src_files) == 0:
        return 1
    if len(out_file) != 1:
        return 1

    # Filter to only C/C++ source files
    src_files = [f for f in src_files if re.search(r"\.cpp$|\.cc$|\.c$|\.cxx$|\.C$", f)]

    # Build command - simplified to match non-hermetic toolchain exactly
    cmd = [HIPCC_PATH]

    # Add hipcc-specific options (--offload-arch, -gline-tables-only)
    cmd.extend(hipcc_compiler_options)

    # Force HIP runtime header to be included first (from non-hermetic wrapper)
    # This ensures proper macro setup before other headers
    cmd.extend(["--include=hip/hip_runtime.h"])

    # Force C++17 dialect
    cmd.extend(["--std=c++17"])

    # Use -fno-gpu-rdc by default
    cmd.extend(["-fno-gpu-rdc", "-fcuda-flush-denormals-to-zero"])

    # Add undefines
    for undef in undefines:
        cmd.append("-U" + undef)

    # Add defines
    for define in defines:
        cmd.append("-D" + define)

    # Add rocm-path
    cmd.extend(["--rocm-path=" + rocm_path_arg])

    # Add cuda_wrappers BEFORE any system includes
    # This provides device-compatible versions of <new>, <cmath>, <algorithm>, etc.
    rocm_cuda_wrappers = os.path.join(
        rocm_path_arg, "lib/llvm/lib/clang", ROCM_CLANG_VERSION, "include/cuda_wrappers"
    )
    cmd.extend(["-isystem", rocm_cuda_wrappers])

    # Define __device__ as a macro so cuda_wrappers headers work correctly
    cmd.extend(["-D__device__=__device__"])

    # Add GPU compiler options (-isystem, -iquote, --sysroot)
    cmd.extend(gpu_compiler_options)

    # -fPIC
    cmd.append("-fPIC")

    # -I .
    cmd.extend(["-I", "."])

    # Add optimization flag
    if len(opt_option) > 0 and int(opt_option[0]) > 0:
        cmd.append("-O2")
    else:
        cmd.append("-g")

    # Add include paths (filter hermetic LLVM headers)
    for inc in include_options:
        # Skip hermetic LLVM headers - they conflict with ROCm's headers
        # ROCm provides its own LLVM headers (including cuda_wrappers) via --rocm-path
        if "/llvm" in inc and "/clang/" in inc:
            continue
        cmd.extend(["-I", inc])

    # Generate dependency file if requested (must come before main compilation)
    if depfiles:
        depfile = depfiles[0]
        dep_cmd = cmd + src_files + ["-M", "-o", depfile]
        if log or VERBOSE:
            Log("Generating dependencies: " + " ".join(dep_cmd))
        exit_status = subprocess.call(dep_cmd)
        if exit_status != 0:
            return exit_status

    # Compile
    cmd.extend(["-c"] + src_files + ["-o", out_file[0]])

    if log or VERBOSE:
        Log(" ".join(cmd))

    return subprocess.call(cmd)


def is_rocm_flag(flag):
    """Check if a flag is ROCm-specific and should be stripped for host compilation.

    Args:
        flag: A compiler flag string

    Returns:
        True if the flag is ROCm-specific and should be removed when using
        the host compiler (clang) or linker, False otherwise.
    """
    # Only strip flags that clang doesn't understand at all
    return (
        flag.startswith("--rocm")
        or flag.startswith("-nohipinc")
        or flag.startswith("--offload-arch")
        or flag.startswith("-fcuda-flush-denormals-to-zero")
        or flag.startswith("-fno-gpu-rdc")
    )


def FilterSysrootFlags(flags, sysroot_override=None):
    """Filter and replace sysroot-related flags for host compilation.

    When using a local (system) sysroot, this function:
    1. Removes existing --sysroot flags
    2. Filters out hermetic sysroot -isystem paths
    3. Adds the override sysroot

    Args:
        flags: List of compiler flags to filter.
        sysroot_override: If set, replaces existing sysroot with this path
                         and filters hermetic sysroot headers.

    Returns:
        Filtered list of flags with sysroot override applied.

    Notes:
        - Keeps hermetic LLVM headers (needed for compilation)
        - Removes hermetic sysroot headers (incompatible with system sysroot)
        - If sysroot_override is None/empty, returns flags unchanged
    """
    if not sysroot_override:
        return flags

    filtered_flags = []
    skip_next = False

    for i, flag in enumerate(flags):
        if skip_next:
            skip_next = False
            continue

        # Remove existing --sysroot flags
        if flag.startswith("--sysroot"):
            # Skip --sysroot and its argument (if separate)
            if "=" not in flag and i + 1 < len(flags):
                skip_next = True
            continue

        # Filter out hermetic sysroot -isystem paths when using system sysroot
        # Keep hermetic LLVM includes but remove hermetic sysroot includes
        if flag == "-isystem":
            next_flag = flags[i + 1] if i + 1 < len(flags) else ""
            # Skip hermetic sysroot headers (but keep hermetic LLVM headers)
            if "/sysroot_" in next_flag:
                skip_next = True
                continue

        filtered_flags.append(flag)

    # Add the override sysroot
    filtered_flags.extend(["--sysroot", sysroot_override])

    return filtered_flags


def InvokeHostCompiler(argv):
    """Invoke host CPU compiler for non-GPU code.

    This function handles standard C++ compilation for CPU code when the
    ROCm toolchain is used but GPU compilation is not needed (no -x rocm flag).

    Args:
        argv: Command-line arguments from Bazel, potentially including combined
              flags like '-isystem path' that need to be split.

    Returns:
        Exit status from the compiler subprocess.

    Notes:
        - Splits combined flags from Bazel features (e.g., '-isystem path' -> ['-isystem', 'path'])
        - Filters out ROCm-specific flags that clang doesn't understand
        - If HOST_SYSROOT is set, uses that sysroot for host compilation and filters hermetic headers
        - If HOST_SYSROOT is not set, uses hermetic sysroot from Bazel flags
    """
    # Split combined flags (e.g., '-isystem path' -> ['-isystem', 'path'])
    split_flags = SplitCombinedFlags(argv)

    # Filter ROCm-specific flags that host compiler doesn't understand
    cpu_compiler_flags = [
        flag
        for flag in split_flags
        if not flag.startswith("--rocm_log") and not is_rocm_flag(flag)
    ]

    # If HOST_SYSROOT is set, override sysroot for host compilation
    if HOST_SYSROOT:
        cpu_compiler_flags = FilterSysrootFlags(cpu_compiler_flags, HOST_SYSROOT)
        if VERBOSE:
            Log("Using system sysroot for host compilation: " + HOST_SYSROOT)

    if VERBOSE:
        Log("Using host CPU compilation")
        Log(" ".join([CPU_COMPILER] + cpu_compiler_flags))

    return subprocess.call([CPU_COMPILER] + cpu_compiler_flags)


def InvokeLinker(argv):
    """Invoke linker to combine GPU and CPU objects.

    This function handles linking when the -pass-exit-codes flag is present.
    It uses the host compiler (clang) as the linker but strips ROCm-specific
    flags that the linker doesn't understand.

    Args:
        argv: Command-line arguments from Bazel.

    Returns:
        Exit status from the linker subprocess.

    Notes:
        - Strips ROCm-specific flags (--offload-arch, --rocm-path, etc.)
        - Uses clang as the linker (via CPU_COMPILER)
    """
    gpu_linker_flags = [
        flag
        for flag in argv
        if not flag.startswith("--rocm_log") and not is_rocm_flag(flag)
    ]

    if VERBOSE:
        Log("Using linker")
        Log(" ".join([CPU_COMPILER] + gpu_linker_flags))

    return subprocess.call([CPU_COMPILER] + gpu_linker_flags)


def main():
    """Main entry point that routes to appropriate compilation mode.

    Parses command-line arguments to determine which compilation mode to use:
    - GPU compilation: if -x rocm flag is present
    - Linking: if -pass-exit-codes flag is present
    - Host CPU compilation: otherwise (default)

    Returns:
        Exit status from the selected compilation mode.
    """
    # Ignore PWD env var
    os.environ["PWD"] = ""

    parser = ArgumentParser(fromfile_prefix_chars="@")
    parser.add_argument("-x", nargs=1)
    parser.add_argument("--rocm_log", action="store_true")
    parser.add_argument("-pass-exit-codes", action="store_true")
    args, leftover = parser.parse_known_args(sys.argv[1:])

    if VERBOSE:
        Log("PWD=" + os.getcwd())
        Log("HIPCC_PATH=" + HIPCC_PATH)
        Log("ROCM_PATH=" + ROCM_PATH)

    if args.x and args.x[0] == "rocm":
        # GPU compilation mode
        if args.rocm_log or VERBOSE:
            Log("-x rocm flag detected")
            Log("Using GPU compilation mode")
        return InvokeHipcc(leftover, log=args.rocm_log)

    elif args.pass_exit_codes:
        # Linking mode
        return InvokeLinker(sys.argv[1:])

    else:
        # Host CPU compilation mode
        return InvokeHostCompiler(sys.argv[1:])


if __name__ == "__main__":
    sys.exit(main())
